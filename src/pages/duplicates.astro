---
import Layout from './layout.astro';
---

<Layout title="Duplicate Files - PharmaStock">
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h1 class="text-3xl font-bold text-gray-900">Duplicate File Finder</h1>
    </div>

    <!-- Directory Input -->
    <div class="bg-white p-6 rounded-lg shadow">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Scan Directory for Duplicates</h3>
      <div class="flex gap-4">
        <input 
          type="text" 
          id="directoryPath" 
          placeholder="Enter directory path to scan..." 
          class="flex-1 border border-gray-300 rounded-md px-3 py-2"
          value="/workspace"
        >
        <button 
          onclick="scanForDuplicates()" 
          class="bg-primary text-white px-6 py-2 rounded-md hover:bg-secondary transition-colors"
        >
          Scan Directory
        </button>
      </div>
      <p class="text-sm text-gray-500 mt-2">
        This will scan the specified directory and find files with identical content using SHA256 hashing.
      </p>
    </div>

    <!-- Results -->
    <div id="resultsSection" class="hidden">
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-lg font-medium text-gray-900">Duplicate Files Found</h3>
          <p id="resultsSummary" class="text-sm text-gray-500"></p>
        </div>
        <div id="duplicatesList" class="divide-y divide-gray-200">
          <!-- Duplicates will be populated here -->
        </div>
      </div>
    </div>

    <!-- Loading State -->
    <div id="loadingState" class="hidden bg-white p-6 rounded-lg shadow">
      <div class="flex items-center justify-center">
        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
        <span class="ml-3 text-gray-600">Scanning directory for duplicates...</span>
      </div>
    </div>

    <!-- Error State -->
    <div id="errorState" class="hidden bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">Error</h3>
          <div class="mt-2 text-sm text-red-700">
            <p id="errorMessage">An error occurred while scanning for duplicates.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    async function scanForDuplicates() {
      const directoryPath = document.getElementById('directoryPath').value.trim();
      
      if (!directoryPath) {
        alert('Please enter a directory path');
        return;
      }

      // Show loading state
      document.getElementById('loadingState').classList.remove('hidden');
      document.getElementById('resultsSection').classList.add('hidden');
      document.getElementById('errorState').classList.add('hidden');

      try {
        const response = await fetch('/api/duplicates', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ directoryPath })
        });

        const data = await response.json();

        // Hide loading state
        document.getElementById('loadingState').classList.add('hidden');

        if (response.ok) {
          displayDuplicates(data.duplicates);
          document.getElementById('resultsSection').classList.remove('hidden');
        } else {
          showError(data.error || 'Failed to scan for duplicates');
        }
      } catch (error) {
        console.error('Error scanning for duplicates:', error);
        document.getElementById('loadingState').classList.add('hidden');
        showError('Network error occurred while scanning for duplicates');
      }
    }

    function displayDuplicates(duplicates) {
      const resultsSummary = document.getElementById('resultsSummary');
      const duplicatesList = document.getElementById('duplicatesList');

      if (duplicates.length === 0) {
        resultsSummary.textContent = 'No duplicate files found.';
        duplicatesList.innerHTML = '<div class="px-6 py-4 text-center text-gray-500">No duplicates found in the specified directory.</div>';
        return;
      }

      resultsSummary.textContent = `Found ${duplicates.length} groups of duplicate files.`;

      duplicatesList.innerHTML = duplicates.map((duplicate, index) => `
        <div class="px-6 py-4">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <h4 class="text-sm font-medium text-gray-900 mb-2">
                Duplicate Group ${index + 1} (${duplicate.count} files)
              </h4>
              <div class="text-xs text-gray-500 mb-3 font-mono break-all">
                Hash: ${duplicate.hash}
              </div>
              <div class="space-y-1">
                ${duplicate.files.map(file => `
                  <div class="flex items-center justify-between bg-gray-50 px-3 py-2 rounded">
                    <span class="text-sm text-gray-700 font-mono text-xs break-all">${file}</span>
                    <button onclick="copyToClipboard('${file.replace(/'/g, "\\'")}')" class="text-primary hover:text-secondary text-xs">
                      Copy Path
                    </button>
                  </div>
                `).join('')}
              </div>
            </div>
          </div>
        </div>
      `).join('');
    }

    function showError(message) {
      document.getElementById('errorMessage').textContent = message;
      document.getElementById('errorState').classList.remove('hidden');
    }

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => {
        // Show a brief success message
        const button = event.target;
        const originalText = button.textContent;
        button.textContent = 'Copied!';
        button.classList.add('text-green-600');
        setTimeout(() => {
          button.textContent = originalText;
          button.classList.remove('text-green-600');
        }, 1000);
      }).catch(err => {
        console.error('Failed to copy text: ', err);
        alert('Failed to copy to clipboard');
      });
    }

    // Allow Enter key to trigger scan
    document.getElementById('directoryPath').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        scanForDuplicates();
      }
    });
  </script>
</Layout>